{
	"name": "mreader",
	"version": "0.0.1",
	"description": "Extract clean Markdown from any URL",
	"type": "module",
	"bin": {
		"mreader": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"prepare": "bun run build",
		"release": "np",
		"test": "bun test",
		"format": "biome check --write .",
		"format:check": "biome check ."
	},
	"keywords": [
		"markdown",
		"reader",
		"readability",
		"article",
		"extractor",
		"cli",
		"url-to-markdown"
	],
	"author": "Roman Ožana",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OzzyCzech/mreader.git"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@extractus/article-extractor": "^8.0.20",
		"turndown": "^7.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@ozzyczech/tsconfig": "^2.0.0",
		"@types/bun": "^1.3.12",
		"@types/node": "^25.6.0",
		"@types/turndown": "^5.0.6",
		"np": "^11.0.3",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	}
}
