{
	"name": "mreader",
	"version": "0.0.1",
	"description": "Extract clean Markdown from any URL",
	"type": "module",
	"bin": {
		"mreader": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch"
	},
	"keywords": [
		"markdown",
		"reader",
		"readability",
		"article",
		"extractor",
		"cli",
		"url-to-markdown"
	],
	"author": "Roman Ožana",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OzzyCzech/mreader.git"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@extractus/article-extractor": "^8.0.20",
		"turndown": "^7.2.4"
	},
	"devDependencies": {
		"@ozzyczech/tsconfig": "^2.0.0",
		"@types/node": "^25.6.0",
		"@types/turndown": "^5.0.6",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	}
}
